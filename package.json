{
  "name": "@ceramicai/sdk",
  "version": "0.1.5",
  "description": "Ceramic AI search tool for the Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ceramic",
    "search",
    "ai-sdk",
    "vercel",
    "web-search",
    "ai",
    "tools"
  ],
  "author": "Ceramic <support@ceramic.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeramicTeam/ceramic-ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/CeramicTeam/ceramic-ai-sdk/issues"
  },
  "homepage": "ceramic.ai",
  "dependencies": {
    "ceramic-ai": "latest",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
